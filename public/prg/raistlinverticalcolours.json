  "layouts": {
    "bank4000": {
      "binary": "prg/RaistlinVerticalColours-4000.bin",
      "size": "0x4000",
      "baseAddress": "0x4000",
      "dataAddress": "0x4000",
      "sysAddress": "0x4100",
      "binaryDataStart": "0x4000",
      "binaryDataEnd": "0x7FFF",
      "borderColor": "0x400D",
      "backgroundColor": "0x400E",
      "saveRestoreLocation": "before",
