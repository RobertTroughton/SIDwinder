        }
      ],
      "memory": {
        "bank4000": [
          {
            "name": "bitmap",
            "sourceOffset": "0x0002",
            "targetAddress": "0x6000",
            "size": "0x0F00"
          },
          {
            "name": "screen",
            "sourceOffset": "0x1F42",
            "targetAddress": "0x5800",
            "size": "0x01E0"
          },
          {
            "name": "color",
            "sourceOffset": "0x232A",
            "targetAddress": "0x5C00",
            "size": "0x01E0"
          },
          {
            "name": "background",
            "sourceOffset": "0x2712",
            "targetAddress": "0x400E",
            "size": "0x0001"
          }
        ],
        "bank8000": [
          {
            "name": "bitmap",
            "sourceOffset": "0x0002",
            "targetAddress": "0xA000",
            "size": "0x0F00"
          },
          {
            "name": "screen",
            "sourceOffset": "0x1F42",
            "targetAddress": "0x9800",
            "size": "0x01E0"
          },
          {
            "name": "color",
            "sourceOffset": "0x232A",
